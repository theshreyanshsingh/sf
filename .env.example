## Webapp env (Next.js) — use Stripe TEST keys

NEXT_PUBLIC_API=http://localhost:7730/api
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (server-only in Next routes; do NOT prefix with NEXT_PUBLIC)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...            # optional, fallback to inline price_data if missing
STRIPE_SUCCESS_URL=http://localhost:3000/workspace/profile?success=1
STRIPE_CANCEL_URL=http://localhost:3000/workspace/profile?canceled=1
STRIPE_PORTAL_RETURN_URL=http://localhost:3000/workspace/profile

# Used to forward verified webhooks to backend (optional if pointing Stripe directly to backend)
INTERNAL_WEBHOOK_TOKEN=

# Copy this file to .env and replace the placeholder values.
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
NEXT_PUBLIC_GOOGLE_CLIENT_SECRET=your_google_client_secret
NEXT_PUBLIC_GITHUB_CLIENT_ID=your_github_client_id
NEXT_PUBLIC_GITHUB_CLIENT_SECRET=your_github_client_secret
NEXT_PUBLIC_NEXTAUTH_SECRET=your_nextauth_secret
NEXT_PUBLIC_NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret
NEXT_PUBLIC_API=http://localhost:7730/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_RELICS_API=https://your-relics-api.example
NEXT_PUBLIC_SNACK_WEB_PLAYER_URL=https://your-snack-web-player.example
NEXT_PUBLIC_PREVIEW_RUNTIME_DEFAULT=webcontainer
OPEN_API_KEY=your_openai_api_key
POLAR_ACCESS_TOKEN=your_polar_access_token
POLAR_SERVER=sandbox
PRODUCT_ID=your_polar_product_id
POLAR_WEBHOOK_SECRET=your_polar_webhook_secret
POLAR_SUCCESS_URL=http://localhost:3000/workspace/profile
NEXT_PUBLIC_FIGMA_CLIENT_ID=your_figma_client_id
FIGMA_CLIENT_SECRET=your_figma_client_secret
STRIPE_PORTAL_RETURN_URL=http://localhost:3000/workspace/profile
STRIPE_SUCCESS_URL=http://localhost:3000/workspace/profile?checkout=success
STRIPE_CANCEL_URL=http://localhost:3000/workspace/profile?checkout=cancelled
STRIPE_SECRET_KEY=your_stripe_secret_key
INTERNAL_WEBHOOK_TOKEN=your_internal_webhook_token

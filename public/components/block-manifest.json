{
  "version": 1,
  "blocks": [
    {
      "id": "sb-hero-classic",
      "label": "Hero section",
      "category": "Hero",
      "description": "Large heading, supporting copy, and primary CTA.",
      "content": "<section data-sb-block-id=\"hero-classic\" style=\"padding:72px 24px; max-width:960px; margin:0 auto; font-family:system-ui,-apple-system,BlinkMacSystemFont,'SF Pro Text',sans-serif;\"><p style=\"font-size:12px; letter-spacing:0.22em; text-transform:uppercase; color:#4a90e2; font-weight:700; margin:0 0 12px;\">LAUNCH READY</p><h1 style=\"font-size:42px; line-height:1.1; margin:0 0 16px; color:#ffffff;\">Launch faster with a tailored hero message.</h1><p style=\"font-size:16px; line-height:1.6; color:#b0b0b6; max-width:560px; margin:0 0 28px;\">Use this section to describe the core value proposition and guide visitors toward a single, confident action.</p><div style=\"display:flex; flex-wrap:wrap; gap:12px;\"><a href=\"#\" style=\"background:#4a90e2; color:#ffffff; padding:10px 18px; border-radius:999px; text-decoration:none; font-weight:600;\">Primary action</a><a href=\"#\" style=\"border:1px solid #2a2a2b; color:#e0e0e6; padding:10px 18px; border-radius:999px; text-decoration:none;\">Secondary link</a></div></section>"
    },
    {
      "id": "sb-feature-grid",
      "label": "Feature grid",
      "category": "Features",
      "description": "Three-column feature cards.",
      "content": "<section data-sb-block-id=\"feature-grid\" style=\"padding:56px 24px; max-width:1040px; margin:0 auto; font-family:system-ui,-apple-system,BlinkMacSystemFont,'SF Pro Text',sans-serif;\"><h2 style=\"font-size:28px; color:#ffffff; margin:0 0 12px;\">Highlight key capabilities.</h2><p style=\"font-size:15px; color:#a0a0a8; margin:0 0 28px;\">Each card is editable. Describe the benefits in a concise way.</p><div style=\"display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:18px;\"><article style=\"border-radius:14px; padding:18px; border:1px solid #2a2a2b; background:#141415;\"><h3 style=\"font-size:16px; color:#ffffff; margin:0 0 8px;\">First highlight</h3><p style=\"font-size:14px; color:#b0b0b6; margin:0;\">Short description of the first value.</p></article><article style=\"border-radius:14px; padding:18px; border:1px solid #2a2a2b; background:#141415;\"><h3 style=\"font-size:16px; color:#ffffff; margin:0 0 8px;\">Second highlight</h3><p style=\"font-size:14px; color:#b0b0b6; margin:0;\">Add a clear explanation for benefit two.</p></article><article style=\"border-radius:14px; padding:18px; border:1px solid #2a2a2b; background:#141415;\"><h3 style=\"font-size:16px; color:#ffffff; margin:0 0 8px;\">Third highlight</h3><p style=\"font-size:14px; color:#b0b0b6; margin:0;\">Use concise copy to make it scannable.</p></article></div></section>"
    },
    {
      "id": "sb-testimonial",
      "label": "Testimonial",
      "category": "Social proof",
      "description": "Quote with author details.",
      "content": "<section data-sb-block-id=\"testimonial\" style=\"padding:40px 24px; max-width:900px; margin:0 auto; font-family:system-ui,-apple-system,BlinkMacSystemFont,'SF Pro Text',sans-serif;\"><div style=\"border:1px solid #2a2a2b; border-radius:16px; padding:24px; background:linear-gradient(135deg, rgba(74,144,226,0.16), rgba(20,20,21,0.96));\"><p style=\"font-size:16px; color:#f5f5ff; margin:0 0 16px;\">“Superblocks helped us ship a complete site in a single afternoon. The workflow feels smooth and fast.”</p><div style=\"display:flex; align-items:center; gap:12px;\"><div style=\"width:40px; height:40px; border-radius:999px; background:#4a90e2; display:flex; align-items:center; justify-content:center; color:#fff; font-weight:700;\">AM</div><div><div style=\"font-size:14px; color:#ffffff; font-weight:600;\">Avery Miles</div><div style=\"font-size:12px; color:#c5c5d0;\">Founder, Launchcraft</div></div></div></div></section>"
    },
    {
      "id": "sb-cta-strip",
      "label": "CTA strip",
      "category": "Conversion",
      "description": "Compact call-to-action strip.",
      "content": "<section data-sb-block-id=\"cta-strip\" style=\"padding:24px; margin:32px auto 0; max-width:960px; font-family:system-ui,-apple-system,BlinkMacSystemFont,'SF Pro Text',sans-serif;\"><div style=\"border-radius:16px; border:1px solid #2a2a2b; background:#0f0f10; padding:20px; display:flex; flex-wrap:wrap; align-items:center; justify-content:space-between; gap:16px;\"><div><p style=\"font-size:13px; text-transform:uppercase; letter-spacing:0.12em; color:#8fa9ff; margin:0 0 6px;\">Ready to go</p><h3 style=\"font-size:18px; color:#ffffff; margin:0;\">Invite users to take the next step.</h3></div><a href=\"#\" style=\"background:#4a90e2; color:#ffffff; padding:10px 18px; border-radius:999px; text-decoration:none; font-weight:600;\">Book a demo</a></div></section>"
    },
    {
      "id": "sb-form-simple",
      "label": "Lead form",
      "category": "Forms",
      "description": "Simple lead capture form.",
      "content": "<section data-sb-block-id=\"lead-form\" style=\"padding:40px 24px; max-width:720px; margin:0 auto; font-family:system-ui,-apple-system,BlinkMacSystemFont,'SF Pro Text',sans-serif;\"><div style=\"border:1px solid #2a2a2b; border-radius:16px; padding:24px; background:#141415;\"><h3 style=\"font-size:20px; color:#ffffff; margin:0 0 8px;\">Stay in the loop</h3><p style=\"font-size:14px; color:#a0a0a8; margin:0 0 18px;\">Collect leads or event RSVPs with a simple form.</p><form data-sb-form-id=\"lead-form\" data-sb-form-name=\"Lead capture\" style=\"display:grid; gap:12px;\"><input name=\"name\" placeholder=\"Full name\" style=\"padding:10px 12px; border-radius:10px; border:1px solid #2a2a2b; background:#0f0f10; color:#ffffff;\"/><input name=\"email\" type=\"email\" placeholder=\"Email address\" style=\"padding:10px 12px; border-radius:10px; border:1px solid #2a2a2b; background:#0f0f10; color:#ffffff;\"/><textarea name=\"notes\" placeholder=\"How can we help?\" rows=\"3\" style=\"padding:10px 12px; border-radius:10px; border:1px solid #2a2a2b; background:#0f0f10; color:#ffffff;\"></textarea><button type=\"submit\" style=\"background:#4a90e2; color:#ffffff; padding:10px 16px; border-radius:999px; border:none; font-weight:600; cursor:pointer;\">Submit</button></form></div></section>"
    }
  ]
}
